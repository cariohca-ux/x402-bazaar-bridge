# x402 Bazaar Bridge — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# REQUIRED: Private key (0x hex) for USDC payment signing
# Generate: your Ethereum wallet private key
# WALLET_KEY=

# OPTIONAL: Wallet address (derived from key if omitted)
# WALLET_ADDRESS=0x...

# OPTIONAL: Max daily spend in USD (default: 1.00)
DAILY_BUDGET_USD=1.00
